# Backblaze B2
B2_KEY_ID=your_key_id_here
B2_APP_KEY=your_app_key_here
B2_BUCKET_NAME=your-bucket-name

# GMI Cloud
GMI_API_KEY=your_gmi_api_key_here

# Google (for Imagen/Veo)
